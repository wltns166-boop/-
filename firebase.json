{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.git/**",
      "**/.github/**",
      "**/node_modules/**",
      "functions/**",
      "*.md",
      "*.gs",
      "insurance-intranet-v2.html"
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
