{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", ".firebaserc", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/analyze",
        "function": { "functionId": "anthropicProxy", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
