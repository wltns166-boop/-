rules_version = '2';

// TEAM TOPS 인트라넷 Firestore 보안 규칙
// 적용: Firebase 콘솔 > Firestore Database > 규칙(Rules) 탭에 붙여넣고 "게시".
//
// 핵심: 로그인(Firebase 인증)한 사용자만 데이터에 접근할 수 있습니다.
// 인증 없이 접속하면 고객정보/팀원정보를 읽거나 쓸 수 없습니다.

service cloud.firestore {
  match /databases/{database}/documents {

    // 인트라넷 데이터(고객/팀원/실적 등)는 로그인한 사용자만 읽기/쓰기 가능
    match /tops/{docId} {
      allow read, write: if request.auth != null;
    }

    // 그 외 모든 경로는 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ──────────────────────────────────────────────────────────────
// [긴급 잠금용] 인증 전환 전에 "지금 당장" 모든 접근을 막아야 한다면
// 아래 내용으로 통째로 교체해 게시하세요. (이 상태에서는 앱도 동작하지 않습니다)
//
// rules_version = '2';
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /{document=**} { allow read, write: if false; }
//   }
// }
// ──────────────────────────────────────────────────────────────
