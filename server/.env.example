# ── 솔라피(SOLAPI) 설정 ──
# 솔라피 콘솔 > 개발/연동 > API Key 관리 에서 발급
SOLAPI_API_KEY=여기에_API_KEY_입력
SOLAPI_API_SECRET=여기에_API_SECRET_입력

# 솔라피에 등록·인증한 발신번호 (숫자만). 알림톡 실패 시 문자 대체발송에 사용
SENDER_PHONE=01000000000

# 카카오 발신 프로필 ID — 채널 연동 후 발급됨 (KA01PF... 형식)
KAKAO_PFID=KA01PF000000000000000000000000

# 승인받은 알림톡 템플릿 ID (KA01TP... 형식)
KAKAO_TEMPLATE_ID=KA01TP000000000000000000000000

# 인트라넷이 열리는 주소 (보안상 정확히 지정 권장, 예: https://intranet.mycompany.com)
ALLOW_ORIGIN=*

PORT=3000
